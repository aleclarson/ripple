{
  "name": "@tsrx/solid",
  "description": "Solid compiler built on @tsrx/core",
  "license": "MIT",
  "author": "Dominic Gannaway",
  "version": "0.1.28",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ripple-TS/ripple.git",
    "directory": "packages/tsrx-solid"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./dynamic": {
      "types": "./types/dynamic.d.ts"
    },
    "./ref": {
      "types": "./types/ref.d.ts",
      "default": "./src/ref.js"
    }
  },
  "dependencies": {
    "@tsrx/core": "workspace:*",
    "esrap": "catalog:default",
    "zimmerframe": "catalog:default"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:default",
    "solid-js": "catalog:default"
  },
  "devDependencies": {
    "@types/estree": "catalog:default",
    "@types/estree-jsx": "catalog:default",
    "typescript": "catalog:default"
  },
  "files": [
    "src",
    "types"
  ]
}
