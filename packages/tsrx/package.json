{
  "name": "@tsrx/core",
  "description": "Core compiler infrastructure for TSRX syntax",
  "license": "MIT",
  "author": "Dominic Gannaway",
  "version": "0.1.11",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ripple-TS/ripple.git",
    "directory": "packages/tsrx"
  },
  "exports": {
    ".": {
      "types": "./src/index.js",
      "default": "./src/index.js"
    },
    "./types": {
      "types": "./types/index.d.ts"
    },
    "./types/estree": {
      "types": "./types/estree.d.ts"
    },
    "./types/estree-jsx": {
      "types": "./types/estree-jsx.d.ts"
    },
    "./types/acorn": {
      "types": "./types/acorn.d.ts"
    },
    "./runtime/ref": {
      "types": "./types/runtime/ref.d.ts",
      "default": "./src/runtime/ref.js"
    },
    "./runtime/events": {
      "types": "./types/runtime/events.d.ts",
      "default": "./src/runtime/events.js"
    },
    "./runtime/hash": {
      "types": "./types/runtime/hash.d.ts",
      "default": "./src/runtime/hash.js"
    },
    "./runtime/html": {
      "types": "./types/runtime/html.d.ts",
      "default": "./src/runtime/html.js"
    },
    "./runtime/language-helpers": {
      "types": "./types/runtime/language-helpers.d.ts",
      "default": "./src/runtime/language-helpers.js"
    },
    "./runtime/iterable": {
      "types": "./types/runtime/iterable.d.ts",
      "default": "./src/runtime/iterable.js"
    },
    "./test-harness/source-mappings": "./tests/shared/source-mappings.js",
    "./test-harness/compile": "./tests/shared/compile.js",
    "./test-harness/runtime/*": "./tests/shared/runtime/*.js",
    "./test-harness/runtime/*.js": "./tests/shared/runtime/*.js",
    "./test-harness/runtime/*.tsrx": "./tests/shared/runtime/*.tsrx"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "catalog:default",
    "@noble/hashes": "catalog:default",
    "@sveltejs/acorn-typescript": "catalog:default",
    "@types/estree-jsx": "catalog:default",
    "@types/estree": "catalog:default",
    "acorn": "catalog:default",
    "esrap": "catalog:default",
    "is-reference": "catalog:default",
    "magic-string": "catalog:default",
    "zimmerframe": "catalog:default"
  },
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.7",
    "@tsrx/preact": "workspace:*",
    "@tsrx/react": "workspace:*",
    "@tsrx/solid": "workspace:*",
    "@tsrx/vue": "workspace:*",
    "@types/node": "catalog:default",
    "@typescript-eslint/types": "catalog:default",
    "@volar/language-core": "catalog:default",
    "preact": "catalog:default",
    "react": "catalog:default",
    "react-dom": "catalog:default",
    "solid-js": "2.0.0-beta.7",
    "typescript": "catalog:default",
    "vscode-languageserver-types": "catalog:default",
    "vue": "3.6.0-beta.12",
    "vue-jsx-vapor": "^3.2.14"
  },
  "files": [
    "src",
    "types"
  ]
}
