{
  "name": "@ripple-ts/vscode-plugin",
  "displayName": "TSRX for VS Code",
  "publisher": "ripple-ts",
  "description": "TSRX JavaScript/TypeScript language support",
  "version": "2.0.11",
  "private": true,
  "author": "Dominic Gannaway",
  "license": "MIT",
  "engines": {
    "vscode": "^1.97.0"
  },
  "homepage": "https://ripple-ts.com",
  "activationEvents": [
    "workspaceContains:**/*.tsrx"
  ],
  "categories": [
    "Programming Languages"
  ],
  "main": "dist/extension.js",
  "type": "module",
  "icon": "icons/logo.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ripple-TS/ripple.git",
    "directory": "vscode-plugin"
  },
  "scripts": {
    "build": "tsdown",
    "repack-vsix": "node scripts/repack-vsix.js",
    "delete-unpacked": "node ../../scripts/remove.js packages/vscode-plugin/vscode-plugin",
    "pkg-name-release": "node ../../scripts/transform-package.js packages/vscode-plugin/package.json name ripple-ts-vscode-plugin",
    "pkg-name-back": "node ../../scripts/transform-package.js packages/vscode-plugin/package.json name @ripple-ts/vscode-plugin",
    "package": "pnpm delete-unpacked && pnpm pkg-name-release && node ../../scripts/regenerate-textmate && vsce package --no-dependencies --out=vscode-plugin.vsix && pnpm pkg-name-back && pnpm repack-vsix || pnpm pkg-name-back",
    "install-package": "code --install-extension vscode-plugin.vsix",
    "build-and-package": "pnpm build && pnpm package",
    "build-package-and-install": "pnpm build && pnpm package && pnpm install-package",
    "build-package-install-and-run": "pnpm build && pnpm package && pnpm install-package && code"
  },
  "dependencies": {
    "@volar/language-core": "catalog:default",
    "@volar/language-server": "catalog:default",
    "@volar/typescript": "catalog:default",
    "@volar/vscode": "catalog:default",
    "@ripple-ts/language-server": "workspace:*",
    "@tsrx/typescript-plugin": "workspace:*",
    "volar-service-typescript": "catalog:default",
    "vscode-languageclient": "catalog:default",
    "vscode-uri": "catalog:default"
  },
  "peerDependencies": {
    "typescript": "catalog:vscode"
  },
  "devDependencies": {
    "@types/vscode": "catalog:default",
    "tsdown": "catalog:default",
    "@vscode/vsce": "catalog:default",
    "adm-zip": "catalog:default",
    "@types/adm-zip": "catalog:default",
    "ovsx": "catalog:default"
  },
  "contributes": {
    "breakpoints": [
      {
        "language": "ripple"
      }
    ],
    "configuration": {
      "title": "Ripple",
      "properties": {
        "ripple.autoClosingTags.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically insert closing tags when typing '>' after a tag name. Note: For Ripple files, you may also need to set 'javascript.autoClosingTags' and 'typescript.autoClosingTags' to false to fully disable this feature."
        },
        "ripple.preferences.preferTypeOnlyAutoImports": {
          "type": "boolean",
          "default": true,
          "description": "Prefer adding 'type' modifier to auto imports when possible"
        },
        "ripple.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable default Ripple formatter"
        }
      }
    },
    "commands": [
      {
        "command": "ripple.goToSourceDefinition",
        "title": "Go to Source Definition",
        "category": "Ripple"
      }
    ],
    "languages": [
      {
        "id": "ripple",
        "aliases": [
          "TSRX",
          "tsrx",
          "Ripple",
          "ripple"
        ],
        "extensions": [
          ".tsrx"
        ],
        "icon": {
          "light": "icons/logo.png",
          "dark": "icons/logo.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ripple",
        "scopeName": "source.tsrx",
        "path": "./syntaxes/tsrx.tmLanguage.json",
        "embeddedLanguages": {
          "meta.jsx.children.js": "javascriptreact",
          "meta.tsx.children.js": "typescriptreact",
          "meta.tag.js": "jsx-tags",
          "meta.tag.without-attributes.js": "jsx-tags",
          "meta.tag.attributes.js.jsx": "javascriptreact",
          "meta.embedded.expression.js": "javascriptreact",
          "source.js.embedded.tsrx": "javascript",
          "source.js.embedded.jsx-children.tsrx": "javascript",
          "source.js.embedded.tsrx-isolated": "javascript",
          "source.css": "css"
        }
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ripple.goToSourceDefinition",
          "when": "tsSupportsSourceDefinition && resourceLangId == ripple",
          "group": "navigation@9"
        }
      ],
      "explorer/context": [
        {
          "command": "typescript.findAllFileReferences",
          "when": "tsSupportsFileReferences && resourceLangId == ripple",
          "group": "4_search"
        }
      ],
      "editor/title/context": [
        {
          "command": "typescript.findAllFileReferences",
          "when": "tsSupportsFileReferences && resourceLangId == ripple"
        }
      ],
      "commandPalette": [
        {
          "command": "typescript.reloadProjects",
          "when": "editorLangId == ripple && typescript.isManagedFile"
        },
        {
          "command": "typescript.goToProjectConfig",
          "when": "editorLangId == ripple && typescript.isManagedFile"
        },
        {
          "command": "typescript.sortImports",
          "when": "supportedCodeAction =~ /(\\s|^)source\\.sortImports\\b/ && editorLangId =~ /^ripple$/"
        },
        {
          "command": "typescript.removeUnusedImports",
          "when": "supportedCodeAction =~ /(\\s|^)source\\.removeUnusedImports\\b/ && editorLangId =~ /^ripple$/"
        }
      ]
    }
  }
}
