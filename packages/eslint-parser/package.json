{
  "name": "@tsrx/eslint-parser",
  "version": "0.3.80",
  "description": "ESLint parser for Ripple (.tsrx files)",
  "type": "module",
  "main": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ripple-TS/ripple.git",
    "directory": "packages/eslint-parser"
  },
  "bugs": {
    "url": "https://github.com/Ripple-TS/ripple/issues"
  },
  "homepage": "https://ripple-ts.com",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "eslint",
    "parser",
    "ripple"
  ],
  "author": "Dominic Gannaway",
  "license": "MIT",
  "scripts": {
    "dist": "perl -pi -e 's/\"main\": \"src\\/index.ts\"/\"main\": \"dist\\/index.js\"/' package.json",
    "src": "perl -pi -e 's/\"main\": \"dist\\/index.js\"/\"main\": \"src\\/index.ts\"/' package.json",
    "build": "pnpm dist && tsdown && pnpm src || pnpm src",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "eslint": "catalog:peer"
  },
  "dependencies": {
    "@tsrx/core": "workspace:*"
  },
  "devDependencies": {
    "@types/eslint": "catalog:default",
    "@types/estree": "catalog:default",
    "@types/node": "catalog:default",
    "tsdown": "catalog:default",
    "typescript": "catalog:default"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
